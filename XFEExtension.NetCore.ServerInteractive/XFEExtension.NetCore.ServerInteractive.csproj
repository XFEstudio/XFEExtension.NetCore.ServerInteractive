<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<Version>1.1.17</Version>
		<Title>XFEExtension.NetCore.ServerInteractive</Title>
		<RepositoryUrl>https://github.com/XFEstudio/XFEExtension.NetCore.ServerInteractive</RepositoryUrl>
		<AnalysisLevel>latest</AnalysisLevel>
		<PackAsTool>False</PackAsTool>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<SignAssembly>True</SignAssembly>
		<Copyright>寰宇朽力网络科技有限公司版权所有</Copyright>
		<PackageProjectUrl>https://github.com/XFEstudio/XFEExtension</PackageProjectUrl>
		<PackageIcon>logoIcon.png</PackageIcon>
		<Description>Server interaction extension, including user identity verification and querying in conjunction with AutoConfig</Description>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>XFE;Server;服务器;XFEExtension</PackageTags>
		<PackageReleaseNotes>
      ## 调整

      新增IsStandardError属性及依赖包版本优化

      本次提交新增IsStandardError属性，完善异常处理逻辑，相关接口和类同步更新。
      项目依赖包版本改为通配符，提升兼容性，版本号升级至1.1.17。

      ## 新增

      无

      ## 严重

      无
    </PackageReleaseNotes>
		<NeutralLanguage>zh-CN</NeutralLanguage>
		<PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
		<Version>$(Version)</Version>
		<Authors>XFEstudio</Authors>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
	</PropertyGroup>

	<ItemGroup>
	  <None Include="..\LICENSE.txt">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\logoIcon.png">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\README.md">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="System.Management" Version="10.0.*" />
		<PackageReference Include="XFEExtension.NetCore" Version="3.3.*" />
		<PackageReference Include="XFEExtension.NetCore.AutoConfig" Version="2.0.*" />
		<PackageReference Include="XFEExtension.NetCore.AutoImplement" Version="1.1.*" />
		<PackageReference Include="XFEExtension.NetCore.XFEConsole" Version="1.2.*" />
	</ItemGroup>

</Project>
