<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<Version>1.1.15</Version>
		<Title>XFEExtension.NetCore.ServerInteractive</Title>
		<RepositoryUrl>https://github.com/XFEstudio/XFEExtension.NetCore.ServerInteractive</RepositoryUrl>
		<AnalysisLevel>latest</AnalysisLevel>
		<PackAsTool>False</PackAsTool>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<SignAssembly>True</SignAssembly>
		<Copyright>寰宇朽力网络科技有限公司版权所有</Copyright>
		<PackageProjectUrl>https://github.com/XFEstudio/XFEExtension</PackageProjectUrl>
		<PackageIcon>logoIcon.png</PackageIcon>
		<Description>Server interaction extension, including user identity verification and querying in conjunction with AutoConfig</Description>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>XFE;Server;服务器;XFEExtension</PackageTags>
		<PackageReleaseNotes>
      ## 调整

      修复异常时状态码未设置并升级版本号

      在 XFEClientRequester.cs 中补充异常处理时的状态码赋值，确保返回结果准确；同时将项目版本号从 1.1.14 升级到 1.1.15。

      ## 新增

      无

      ## 严重

      无
    </PackageReleaseNotes>
		<NeutralLanguage>zh-CN</NeutralLanguage>
		<PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
		<Version>$(Version)</Version>
		<Authors>XFEstudio</Authors>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
	</PropertyGroup>

	<ItemGroup>
	  <None Include="..\LICENSE.txt">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\logoIcon.png">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\README.md">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="System.Management" Version="10.0.3" />
		<PackageReference Include="XFEExtension.NetCore" Version="3.3.10" />
		<PackageReference Include="XFEExtension.NetCore.AutoConfig" Version="2.0.*" />
		<PackageReference Include="XFEExtension.NetCore.AutoImplement" Version="1.1.*" />
		<PackageReference Include="XFEExtension.NetCore.XFEConsole" Version="1.2.3" />
	</ItemGroup>

</Project>
