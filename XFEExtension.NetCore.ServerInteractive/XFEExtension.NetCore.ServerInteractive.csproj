<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<Version>2.0.1</Version>
		<Title>XFEExtension.NetCore.ServerInteractive</Title>
		<RepositoryUrl>https://github.com/XFEstudio/XFEExtension.NetCore.ServerInteractive</RepositoryUrl>
		<AnalysisLevel>latest</AnalysisLevel>
		<PackAsTool>False</PackAsTool>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<SignAssembly>True</SignAssembly>
		<Copyright>寰宇朽力网络科技有限公司版权所有</Copyright>
		<PackageProjectUrl>https://github.com/XFEstudio/XFEExtension</PackageProjectUrl>
		<PackageIcon>logoIcon.png</PackageIcon>
		<Description>Server interaction extension, including user identity verification and querying in conjunction with AutoConfig</Description>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>XFE;Server;服务器;XFEExtension</PackageTags>
		<PackageReleaseNotes>
      ## 调整

      统一IP相关命名，升级依赖并优化接口实现

      本次提交主要内容如下：

      - 全面统一与“IP地址”相关的类、属性、方法、服务等命名（如 IpAddress → IPAddress，IpBanner → IPBanner 等），包括 JSON 字段、请求名、参数名等，提升代码一致性。
      - 同步调整所有接口、抽象类、实现类及配置项的相关属性和委托名，保持命名规范统一。
      - 适配业务逻辑，确保 IP 判断、存储、序列化、权限校验等环节与新命名一致，用户登录相关 LastIpAddress 也统一为 LastIPAddress。
      - 客户端与服务端的请求注册、服务注册等同步为新命名，保证前后端一致。
      - 升级部分依赖包版本，项目自身版本号提升至 2.0.1。
      - 优化控制台输出及调试信息，保持接口和方法兼容性，便于后续维护和扩展。

      ## 新增

      无

      ## 严重

      无
    </PackageReleaseNotes>
		<NeutralLanguage>zh-CN</NeutralLanguage>
		<PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
		<Version>$(Version)</Version>
		<Authors>XFEstudio</Authors>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
	</PropertyGroup>

	<ItemGroup>
	  <None Include="..\LICENSE.txt">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\logoIcon.png">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\README.md">
	    <Pack>True</Pack>
	    <PackagePath>\</PackagePath>
	  </None>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="System.Management" Version="11.0.0-preview.2.26159.112" />
		<PackageReference Include="XFEExtension.NetCore" Version="4.0.*" />
		<PackageReference Include="XFEExtension.NetCore.AutoConfig" Version="2.0.*" />
		<PackageReference Include="XFEExtension.NetCore.AutoImplement" Version="1.1.*" />
		<PackageReference Include="XFEExtension.NetCore.XFEConsole" Version="2.0.*" />
	</ItemGroup>

</Project>
